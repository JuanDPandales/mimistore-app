{
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterFramework": [
        "@testing-library/jest-dom"
    ],
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
        "src/**/*.{ts,tsx}",
        "!src/main.tsx"
    ],
    "coverageThreshold": {
        "global": {
            "branches": 80,
            "functions": 80,
            "lines": 80,
            "statements": 80
        }
    }
}